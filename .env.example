# ═══════════════════════════════════════════════════════════════════════════
# Lucioles — template de configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copier ce fichier en .env.local (dev) ou .env.production (prod)
# et renseigner les valeurs réelles.
# NE JAMAIS committer .env.local ou .env.production — voir .gitignore

# ── Supabase ─────────────────────────────────────────────────────────────────
# Disponibles dans : https://supabase.com/dashboard/project/<ref>/settings/api
FLUTTER_SUPABASE_URL=https://<ref>.supabase.co
FLUTTER_SUPABASE_ANON_KEY=<anon_key>

# ── OAuth providers (optionnel) ───────────────────────────────────────────────
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
